```java
package ch02;

public class VarEx2 {

	public static void main(String[] args) {
		/*
		 * 변수, 상수, 리터럴
		 * - 변수(variable) : 하나의 값을 저장하기 위한 공간
		 * - 상수(contant) : 한번만 값을 저장 가능한 변수
		 * - 리터럴(literal) : 그 자체로 값을 의미하는 것(기존의 상수)
		 */
		
		//변수 : 변수는 공간을 의미하므로 공간안에 들어갈 값은 변경 가능하다
		int score = 100;
		score = 200;
		
		//상수 : 변수이지만 한 번만 값을 저장 가능하므로 한번 저장한 값은 변경불가
		final int MAX = 100;
//		MAX = 200; >> 컴파일에러

	}

}
```
