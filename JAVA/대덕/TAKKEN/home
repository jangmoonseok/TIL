	void battle(Character my,Character enemy) {
		System.out.println("=========== 전투 시작 ===========");
		int turn = 10;
		battle : while(true) {
					if(turn > 0) {
						System.out.println("1.공격\t2.방어\t3.캐릭터정보");
						int input = ScanUtil.nextInt();
						switch(input) {
						case 1:
							my.attack(enemy);
							if(enemy.hp <= 0) {
								System.out.println("========== 전투 종료 ==========");
								System.out.println("\t  승리!");
								System.out.println("============================");
								break battle;
							}
							if(my.hp <= 0) {
								System.out.println("========== 전투 종료 ==========");
								System.out.println("\t패배...!");
								System.out.println("============================");
								break battle;
							}
							turn--;
							System.out.println("남은 턴 : " + turn);
							System.out.println("=============================");
							break;
						case 2:							
							my.defence(enemy);
							turn--;
							System.out.println("남은 턴 : " + turn);
							System.out.println("=============================");
							break;
						case 3:
							my.status();
							break;
						}
					}else {
						System.out.println("========== 전투 종료 ==========");
						if(my.hp > enemy.hp) {
							System.out.println("\t  승리!");
						}else if(my.hp < enemy.hp) {
							System.out.println("\t패배...!");
						}else {
							System.out.println("\t  Draw");
						}
						System.out.println("============================");
						break;
					}
				}
	}

