		System.out.println("캐릭터를 선택해주세요.");
		System.out.println("1.Jin 2.Paul 3.Heihachi 4.Hwoarang >");
		int cPick = ScanUtil.nextInt();
		switch(cPick) {
		case 1:
			my = new Jin();
